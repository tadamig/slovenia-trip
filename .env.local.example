NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# ——— Offline ingestion blogów (Tor A) ———
# Brave Search API (przeszukuje cały internet w poszukiwaniu artykułów blogowych)
# Klucz z https://brave.com/search/api/ (darmowy tier ~2000 zapytań/mies.)
BRAVE_API_KEY=YOUR_BRAVE_API_KEY
# Sekret chroniący endpoint /api/ingest (dowolny długi losowy ciąg)
INGEST_SECRET=YOUR_INGEST_SECRET
# Klucz service_role Supabase — TYLKO server-side, do zapisu curated_places
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
# Sekret dla Vercel Cron (/api/cron/refresh-curated). Vercel sam dodaje go w nagłówku.
CRON_SECRET=YOUR_CRON_SECRET
