NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# ——— Offline ingestion blogów (Tor A) ———
# Google Custom Search JSON API (do znajdowania artykułów blogowych)
GOOGLE_CSE_KEY=YOUR_GOOGLE_CSE_KEY
GOOGLE_CSE_CX=YOUR_GOOGLE_CSE_CX
# Sekret chroniący endpoint /api/ingest (dowolny długi losowy ciąg)
INGEST_SECRET=YOUR_INGEST_SECRET
# Klucz service_role Supabase — TYLKO server-side, do zapisu curated_places
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
# Sekret dla Vercel Cron (/api/cron/refresh-curated). Vercel sam dodaje go w nagłówku.
CRON_SECRET=YOUR_CRON_SECRET
